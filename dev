#!/bin/bash

# To view the license please visit https://github.com/IDNI/tau-lang/blob/main/LICENSE.md

echo "dev - Tau development helper scripts"

help() {
	echo "Usage: ./dev <SCRIPT> [SCRIPT_OPTIONS...]"
	echo ""
	echo "  -D options may appear anywhere; see scripts/README.md"
	echo "  TAU_BUILD_JOBS: -D, env, or auto (half of CPU cores)"
	echo ""
	echo "Available scripts:"
	for script in scripts/*.sh; do
		if [ -f "$script" ]; then
			echo -e "\t$(basename "$script" .sh)"
		fi
	done
	echo "For more information, see scripts/README.md"
}

error() {
	echo -e "\nError: $1\n"
	help
	exit 1
}

# Check if first argument is provided
if [ $# -eq 0 ]; then
	error "No script name provided"
fi

script_name="$1"

if [ "$script_name" == "help" ] || [ "$script_name" == "--help" ] || [ "$script_name" == "-h" ]; then
	help
	exit 0
fi

if [ ! -f external/parser/scripts/devrc ]; then
	echo "Initializing parser submodule..."
	git submodule update --init --recursive
fi
source external/parser/scripts/devrc

if resolve_script "$(pwd)" "$@"; then
	exit 0
else
	error "'scripts/${script_name%.sh}.sh' not found"
fi
